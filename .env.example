REDIS_PASSWORD=your_redis_password

KAFKA_BROKERS=your-kafka-endpoint.upstash.io:9092
KAFKA_USERNAME=your_kafka_username
KAFKA_PASSWORD=your_kafka_password

JWT_SECRET=your_super_secret_jwt_key
