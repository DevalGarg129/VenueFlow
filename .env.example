PORT=3000
GATEWAY_PORT=8080
WS_PORT=5000
USER_SERVICE_PORT=4001
CROWD_SERVICE_PORT=4002
QUEUE_SERVICE_PORT=4003
MATCH_SERVICE_PORT=4004
